# Development environment — local variables
# Copy this file to .env.development and fill in your values.
# Run: cp .env.development.example .env.development
# Then: npm run env:dev && npm run env:check
#
# NEVER commit .env.development (it is git-ignored).
# This file (the example) IS committed so new contributors have a reference.

# -------------------------------------------------------
# App environment marker
# -------------------------------------------------------
APP_ENV=development
EXPO_PUBLIC_ENVIRONMENT=development

# -------------------------------------------------------
# Supabase (development project)
# Create a free project at https://supabase.com/dashboard
# Settings > API > Project URL and Project API Keys
# -------------------------------------------------------
EXPO_PUBLIC_SUPABASE_URL=https://your-dev-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-dev-anon-key-here

# Server-side service-role key (backend only, NOT in EXPO_PUBLIC_*)
SUPABASE_URL=https://your-dev-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-dev-service-role-key-here

# -------------------------------------------------------
# API server
# -------------------------------------------------------
# URL the mobile app uses to reach the local API server
EXPO_PUBLIC_API_URL=http://localhost:3001
# Legacy REST endpoints (enhanced-bounty-service, skill-service, etc.)
EXPO_PUBLIC_LEGACY_API_BASE_URL=http://localhost:3001

# -------------------------------------------------------
# Database (local PostgreSQL or Supabase Postgres)
# -------------------------------------------------------
DATABASE_URL=postgresql://postgres:password@localhost:5432/bountyexpo_dev

# -------------------------------------------------------
# Stripe (test mode keys)
# Publishable key: https://dashboard.stripe.com/test/apikeys
# -------------------------------------------------------
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_dev_key_here
STRIPE_SECRET_KEY=sk_test_your_dev_secret_here
STRIPE_WEBHOOK_SECRET=whsec_your_dev_webhook_secret

# -------------------------------------------------------
# Auth providers (optional in local dev — leave empty to skip)
# -------------------------------------------------------
# Google Sign-In (https://console.cloud.google.com/apis/credentials)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Apple Sign-In (https://developer.apple.com/account/resources/identifiers)
EXPO_PUBLIC_APPLE_AUTH_SERVICE_ID=com.bountyexpo.service
EXPO_PUBLIC_APPLE_AUTH_REDIRECT_URI=https://bountyfinder.app/auth/callback

# -------------------------------------------------------
# Analytics & monitoring (optional in local dev)
# -------------------------------------------------------
EXPO_PUBLIC_MIXPANEL_TOKEN=dev_mixpanel_token_here
EXPO_PUBLIC_SENTRY_DSN=

# -------------------------------------------------------
# Server configuration
# -------------------------------------------------------
PORT=3001
NODE_ENV=development
LOG_LEVEL=debug
DEBUG=true
