# Example .env.preview (Preview / Staging)
# Copy to `.env.preview` and fill sensitive values locally or via your secret manager.

# API
API_BASE_URL=http://localhost:3001
API_PORT=3001

# Supabase (public keys for client builds go as EXPO_PUBLIC_*)
EXPO_PUBLIC_SUPABASE_URL=https://your-preview-supabase.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=anon_preview_key_here

# Stripe (do NOT commit real secrets)
STRIPE_PUBLISHABLE_KEY=pk_test_preview
STRIPE_SECRET_KEY=sk_test_preview
STRIPE_WEBHOOK_SECRET=whsec_preview_example

# Analytics / Monitoring (examples)
EXPO_PUBLIC_MIXPANEL_TOKEN=preview_mixpanel_token
EXPO_PUBLIC_SENTRY_DSN=

# Misc
EXPO_PUBLIC_ENVIRONMENT=preview
# Preview / Staging env template (examples only)
NODE_ENV=preview
PORT=3001
DATABASE_URL=postgres://postgres:password@staging-db:5432/bountyexpo_preview
EXPO_PUBLIC_SUPABASE_URL=https://your-staging-supabase-url
EXPO_PUBLIC_SUPABASE_ANON_KEY=anon_preview_key
SUPABASE_SERVICE_ROLE_KEY=service_role_key_preview
STRIPE_SECRET_KEY=""
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_preview
EXPO_PUBLIC_API_URL=https://api-staging.example.com
EXPO_PUBLIC_ENVIRONMENT=preview
# Fill with actual staging values in CI or EAS secrets
