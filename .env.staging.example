# Staging environment variables
# Copy this file to .env.staging and fill in your values.
# Run: cp .env.staging.example .env.staging
# Then: npm run env:staging && npm run env:check
#
# For EAS builds, inject secrets via: eas secret:create --scope project
# NEVER commit .env.staging (it is git-ignored).
# This file (the example) IS committed so engineers have a reference.

# -------------------------------------------------------
# App environment marker
# -------------------------------------------------------
APP_ENV=staging
EXPO_PUBLIC_ENVIRONMENT=staging

# -------------------------------------------------------
# Supabase (staging project)
# Use a SEPARATE Supabase project from dev and production.
# Settings > API > Project URL and Project API Keys
# -------------------------------------------------------
EXPO_PUBLIC_SUPABASE_URL=https://your-staging-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-staging-anon-key-here

# Server-side service-role key (backend only, NOT in EXPO_PUBLIC_*)
SUPABASE_URL=https://your-staging-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-staging-service-role-key-here

# -------------------------------------------------------
# API server (staging backend)
# -------------------------------------------------------
EXPO_PUBLIC_API_URL=https://api-staging.yourdomain.com
EXPO_PUBLIC_LEGACY_API_BASE_URL=https://api-staging.yourdomain.com

# -------------------------------------------------------
# Database (staging PostgreSQL)
# -------------------------------------------------------
DATABASE_URL=postgresql://postgres:password@staging-db-host:5432/bountyexpo_staging

# -------------------------------------------------------
# Stripe (test-mode keys — use test keys for staging, NOT live keys)
# Publishable key: https://dashboard.stripe.com/test/apikeys
# -------------------------------------------------------
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_staging_key_here
STRIPE_SECRET_KEY=sk_test_your_staging_secret_here
STRIPE_WEBHOOK_SECRET=whsec_your_staging_webhook_secret

# -------------------------------------------------------
# Auth providers
# -------------------------------------------------------
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-staging-ios-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your-staging-android-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-staging-web-client-id.apps.googleusercontent.com

EXPO_PUBLIC_APPLE_AUTH_SERVICE_ID=com.bountyexpo.service
EXPO_PUBLIC_APPLE_AUTH_REDIRECT_URI=https://bountyfinder.app/auth/callback

# -------------------------------------------------------
# Analytics & monitoring
# -------------------------------------------------------
EXPO_PUBLIC_MIXPANEL_TOKEN=staging_mixpanel_token_here
EXPO_PUBLIC_SENTRY_DSN=https://example@sentry.io/staging-project-id

# -------------------------------------------------------
# Server configuration
# -------------------------------------------------------
PORT=3001
NODE_ENV=staging
LOG_LEVEL=info
DEBUG=false
