# Example .env.production (Production)
# Copy to `.env.production` in a secure location and set real secrets via your secret manager or CI.

# API
API_BASE_URL=https://api.yourdomain.com
API_PORT=3001

# Supabase (public keys for client builds go as EXPO_PUBLIC_*)
EXPO_PUBLIC_SUPABASE_URL=https://your-supabase.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=anon_production_key_here

# Stripe
STRIPE_PUBLISHABLE_KEY=pk_live_example
STRIPE_SECRET_KEY=sk_live_example
STRIPE_WEBHOOK_SECRET=whsec_production_example

# Analytics / Monitoring
EXPO_PUBLIC_MIXPANEL_TOKEN=prod_mixpanel_token
EXPO_PUBLIC_SENTRY_DSN=https://example@sentry.io/123

EXPO_PUBLIC_ENVIRONMENT=production
# Production env template (examples only) - NEVER commit real secrets here
NODE_ENV=production
PORT=3001
DATABASE_URL=postgres://postgres:password@prod-db:5432/bountyexpo
EXPO_PUBLIC_SUPABASE_URL=https://your-production-supabase-url
EXPO_PUBLIC_SUPABASE_ANON_KEY=anon_prod_key
SUPABASE_SERVICE_ROLE_KEY=service_role_key_prod
STRIPE_SECRET_KEY=""
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx
EXPO_PUBLIC_API_URL=https://api.example.com
EXPO_PUBLIC_ENVIRONMENT=production
# Inject real secrets via secret manager or CI environment variables
